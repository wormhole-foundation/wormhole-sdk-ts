{
  "name": "@wormhole-foundation/sdk-connect",
  "version": "1.20.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wormhole-foundation/wormhole-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/wormhole-foundation/wormhole-sdk-ts/issues"
  },
  "homepage": "https://github.com/wormhole-foundation/wormhole-sdk-ts#readme",
  "directories": {
    "test": "__tests__"
  },
  "license": "Apache-2.0",
  "main": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "module": "./dist/esm/index.js",
  "author": "",
  "description": "The core package for the Connect SDK, used in conjunction with 1 or more of the chain packages",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./routes": {
      "types": "./dist/esm/routes/index.d.ts",
      "import": "./dist/esm/routes/index.js",
      "default": "./dist/esm/routes/index.js"
    },
    "./tokens": {
      "types": "./dist/esm/tokens.d.ts",
      "import": "./dist/esm/tokens.js",
      "default": "./dist/esm/tokens.js"
    },
    "./tasks": {
      "types": "./dist/esm/tasks.d.ts",
      "import": "./dist/esm/tasks.js",
      "default": "./dist/esm/tasks.js"
    },
    "./circle-api": {
      "types": "./dist/esm/circle-api.d.ts",
      "import": "./dist/esm/circle-api.js",
      "default": "./dist/esm/circle-api.js"
    },
    "./whscan-api": {
      "types": "./dist/esm/whscan-api.d.ts",
      "import": "./dist/esm/whscan-api.js",
      "default": "./dist/esm/whscan-api.js"
    }
  },
  "typesVersions": {
    "*": {
      "routes": [
        "./dist/esm/routes/index.d.ts"
      ],
      "tokens": [
        "./dist/esm/tokens.d.ts"
      ],
      "tasks": [
        "./dist/esm/tasks.d.ts"
      ],
      "circle-api": [
        "./dist/esm/circle-api.d.ts"
      ],
      "whscan-api": [
        "./dist/esm/whscan-api.d.ts"
      ],
      "*": [
        "./dist/esm/index.d.ts"
      ]
    }
  },
  "files": [
    "dist/esm"
  ],
  "keywords": [
    "wormhole",
    "sdk",
    "typescript",
    "connect"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "sideEffects": false,
  "scripts": {
    "build:esm": "tsc -p ./tsconfig.esm.json",
    "build": "npm run build:esm",
    "rebuild": "npm run clean && npm run build",
    "clean": "rm -rf ./dist && rm -rf ./.turbo",
    "lint": "npm run prettier && eslint --fix ./src --ext .ts",
    "prettier": "prettier --write ./src",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config ./jest.config.ts --testMatch '**/__tests__/**/*.test.ts'",
    "coverage": "jest --config ./jest.config.ts --coverage",
    "docs": "typedoc"
  },
  "dependencies": {
    "@wormhole-foundation/sdk-base": "1.20.0",
    "@wormhole-foundation/sdk-definitions": "1.20.0",
    "axios": "^1.4.0"
  },
  "type": "module",
  "devDependencies": {
    "@fetch-mock/jest": "^0.2.20"
  }
}
