{
  "name": "@wormhole-foundation/sdk-base",
  "version": "1.20.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wormhole-foundation/wormhole-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/wormhole-foundation/wormhole-sdk-ts/issues"
  },
  "homepage": "https://github.com/wormhole-foundation/wormhole-sdk-ts#readme",
  "directories": {
    "test": "__tests__"
  },
  "license": "Apache-2.0",
  "main": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./constants": {
      "types": "./dist/esm/constants/index.d.ts",
      "import": "./dist/esm/constants/index.js",
      "default": "./dist/esm/constants/index.js"
    },
    "./tokens": {
      "types": "./dist/esm/constants/tokens/index.d.ts",
      "import": "./dist/esm/constants/tokens/index.js",
      "default": "./dist/esm/constants/tokens/index.js"
    },
    "./contracts": {
      "types": "./dist/esm/constants/contracts/index.d.ts",
      "import": "./dist/esm/constants/contracts/index.js",
      "default": "./dist/esm/constants/contracts/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "tokens": [
        "./dist/esm/constants/tokens/index.d.ts"
      ],
      "contracts": [
        "./dist/esm/constants/contracts/index.d.ts"
      ],
      "*": [
        "./dist/esm/index.d.ts"
      ]
    }
  },
  "files": [
    "dist/esm"
  ],
  "dependencies": {
    "@scure/base": "^1.1.3",
    "binary-layout": "^1.0.3"
  },
  "sideEffects": false,
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config ./jest.config.ts __tests__/*.ts",
    "testamt": "jest --config ../../jest.config.ts __tests__/amount.ts",
    "build:esm": "tsc -p ./tsconfig.esm.json",
    "build": "npm run build:esm",
    "rebuild": "npm run clean && npm run build",
    "clean": "rm -rf ./dist && rm -rf ./.turbo",
    "typecheck": "cp ./__tests__/typechecks/index.test-d.ts ./dist/esm/ && tsd",
    "lint": "npm run prettier && eslint --fix ./src --ext .ts",
    "prettier": "prettier --write ./src"
  },
  "type": "module"
}
